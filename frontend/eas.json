{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "apk",
        "releaseChannel": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
