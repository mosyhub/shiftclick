{
  "expo": {
    "name": "Shift 'N Click",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Shift_Click.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Shift_Click.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.shiftclick.frontend",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@react-native-firebase/app"
      ],
      [
        "@react-native-firebase/messaging"
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.666977520356-v29bcn2f0pupvm7mgpdtoc4g9vbgktrv"
        }
      ]
    ],
    "scheme": "myapp",
    "developmentClient": {
      "silentLaunchAndroidActivity": true
    },
    "extra": {
      "eas": {
        "projectId": "76720223-91d7-4c14-a580-9a0188a2beec"
      }
    },
    "owner": "eisergryn"
  }
}